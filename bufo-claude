#!/usr/bin/env python3
"""bufo-claude — a transparent PTY wrapper around `claude`.

Run claude through this (e.g. `alias claude=bufo-claude`) so the desk buddy can
answer AskUserQuestion prompts natively. The wrapper spawns the real claude in a
pseudo-terminal and passes stdin/stdout through unchanged — you get a normal
claude session — while listening on a unix socket. When you tap an answer on the
buddy, the bridge connects to that socket and the wrapper types the keystrokes
into the pty. The picker receives them as if you'd typed them: a native answer in
your real terminal, no tmux, no "Error:".

Permissions still go through the existing PermissionRequest hook.
"""
import errno
import fcntl
import os
import pty
import select
import signal
import socket
import sys
import termios
import threading
import tty

SOCK = f"/tmp/bufo-pty-{os.getpid()}.sock"


def _set_winsize(master):
    try:
        s = fcntl.ioctl(sys.stdout.fileno(), termios.TIOCGWINSZ, b"\x00" * 8)
        fcntl.ioctl(master, termios.TIOCSWINSZ, s)
    except Exception:
        pass


def _control_server(master):
    """Accept connections from the bridge; write received bytes into the pty."""
    try:
        os.unlink(SOCK)
    except OSError:
        pass
    srv = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    srv.bind(SOCK)
    srv.listen(8)
    while True:
        try:
            conn, _ = srv.accept()
        except OSError:
            break
        try:
            data = conn.recv(512)
            if data:
                os.write(master, data)   # inject keystrokes into claude
        except OSError:
            pass
        finally:
            try:
                conn.close()
            except OSError:
                pass


def main():
    # Tell the child (claude) + its hooks how the bridge can reach this session.
    os.environ["BUFO_PTY_SOCK"] = SOCK

    pid, master = pty.fork()
    if pid == 0:
        # Child: become the real claude. execvp uses PATH (shell aliases don't
        # apply here), so `alias claude=bufo-claude` won't recurse.
        try:
            os.execvp("claude", ["claude"] + sys.argv[1:])
        except Exception as e:
            sys.stderr.write(f"bufo-claude: cannot exec claude: {e}\n")
        os._exit(127)

    _set_winsize(master)
    signal.signal(signal.SIGWINCH, lambda *a: _set_winsize(master))
    threading.Thread(target=_control_server, args=(master,), daemon=True).start()

    old = None
    try:
        old = termios.tcgetattr(sys.stdin)
        tty.setraw(sys.stdin.fileno())
    except Exception:
        pass

    try:
        while True:
            try:
                r, _, _ = select.select([sys.stdin, master], [], [])
            except OSError as e:
                if e.errno == errno.EINTR:
                    continue
                break
            if sys.stdin in r:
                try:
                    d = os.read(sys.stdin.fileno(), 65536)
                except OSError:
                    d = b""
                if d:
                    os.write(master, d)
            if master in r:
                try:
                    d = os.read(master, 65536)
                except OSError:
                    d = b""
                if not d:
                    break
                os.write(sys.stdout.fileno(), d)
    finally:
        if old:
            try:
                termios.tcsetattr(sys.stdin, termios.TCSADRAIN, old)
            except Exception:
                pass
        try:
            os.unlink(SOCK)
        except OSError:
            pass

    try:
        _, status = os.waitpid(pid, 0)
        code = os.WEXITSTATUS(status) if os.WIFEXITED(status) else 1
    except OSError:
        code = 0
    os._exit(code)


if __name__ == "__main__":
    main()
